# ============================================================================
# macOS Host-Specific Environment Variables
# ============================================================================
# This file is sourced early in ~/.zshrc (before shared config)

# Antidote plugin manager
# For Apple Silicon Macs, use /opt/homebrew/share/antidote
# For Intel Macs, use /usr/local/share/antidote
export ANTIDOTE_DIR="/opt/homebrew/share/antidote"

# System utility for opening files and URLs
# 'open' is the macOS command for opening files with default applications
export OPEN_WITH="open"
