{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": true,
  "model": "deepseek/deepseek-v4-pro",
  "small_model": "deepseek/deepseek-v4-flash",
  "plugin": [
    "superpowers@git+https://github.com/obra/superpowers.git",
    "opencode-shell-strategy",
    "opencode-dynamic-context-pruning",
    "opencode-notificator"
  ],
  "mcp": {
    "github": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-github"],
      "enabled": true,
      "timeout": 10000,
      "environment": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "{env:GITHUB_API_KEY}"
      }
    },
    "grep": {
      "type": "remote",
      "url": "https://mcp.grep.app",
      "enabled": true,
      "timeout": 10000
    },
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": true,
      "timeout": 10000
    },
    "neovim": {
      "type": "local",
      "command": ["npx", "-y", "mcp-neovim-server"],
      "enabled": true,
      "timeout": 10000,
      "environment": {
        "NVIM_SOCKET_PATH": "{env:NVIM_SOCKET_PATH}"
      }
    },
    "chrome-devtools": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "chrome-devtools-mcp@latest",
        "--executablePath=/usr/bin/chromium"
      ],
      "enabled": true,
      "timeout": 30000
    }
  },
  "tools": {
    // Disable MCP tools globally by default, enable per-project as needed
    "github_*": false,
    "grep_*": false,
    "context7_*": false,
    "neovim_*": false,
    "chrome_devtools_*": false
  },
  "permission": {
    // Deny MCP tools globally by default, allow per-project as needed
    "github_*": "deny",
    "grep_*": "deny",
    "context7_*": "deny",
    "neovim_*": "deny",
    "chrome_devtools_*": "deny"
  },
  "agent": {
    "explore": {
      "description": "Read-only codebase exploration and context gathering",
      "model": "deepseek/deepseek-v4-flash",
      "permission": {
        "write": "deny",
        "edit": "deny",
        "bash": "deny"
      }
    },
    "general": {
      "model": "deepseek/deepseek-v4-pro",
      "steps": 15
    },
    "reviewer": {
      "description": "Code review and analysis — read files and suggest improvements without making changes",
      "mode": "subagent",
      "model": "deepseek/deepseek-v4-flash",
      "permission": {
        "write": "deny",
        "edit": "deny",
        "bash": "deny"
      },
      "prompt": "You are a code reviewer. Read and analyze code changes, identify bugs, suggest improvements, and check for consistency with project conventions. Do NOT make any edits — only report findings."
    }
  }
}

