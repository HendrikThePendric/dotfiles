# ============================================================================
# Ubuntu Host-Specific Environment Variables
# ============================================================================
# This file is sourced early in ~/.zshrc (before shared config)

# Antidote plugin manager
export ANTIDOTE_DIR="/usr/share/zsh-antidote"

# System utility for opening files and URLs
# 'xdg-open' is the Linux command for opening files with default applications
export OPEN_WITH="xdg-open"
